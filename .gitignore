# --- Credentials and local config ---
.env
*.local
gcloud-key*.json

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.Python
build/
dist/

# --- Virtualenvs ---
.venv/
venv/
env/

# --- Jupyter ---
# Notebooks are local exploration; only the curated analysis notebook is shared.
.ipynb_checkpoints/
notebooks/*
!notebooks/analysis.ipynb

# --- Data: keep slim shareable parquet, exclude heavy ones ---
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
!data/processed/hn_ai_slim.parquet

# --- Model checkpoints and embeddings (regenerate from src) ---
experiments/*
!experiments/.gitkeep
*.bin
*.safetensors
*.npy
*.npz
*.pkl
*.pickle
*.pt
*.pth

# --- Results: track CSVs and figures so collaborators can remix without rerunning ---
# (CSVs total ~12 MB, dominated by sentiment_by_topic_W.csv)
results/*.json

# --- HuggingFace / NLTK caches if a user puts them here ---
.cache/
nltk_data/

# --- OS / IDE cruft ---
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
